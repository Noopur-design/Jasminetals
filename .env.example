# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must NEVER be committed.
# Only NEXT_PUBLIC_* values reach the browser — keep everything else secret.

# ── Firebase web config (PUBLIC — safe to expose in the browser) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC) ──
# Sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Comma-separated owner-admin emails (full /internal access).
ADMIN_EMAILS=

# Direct admin password (login at /admin without Google). Use a strong value.
ADMIN_PASSWORD=

# Firebase Admin service account (Console → Project settings → Service accounts).
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Production data store (REQUIRED on Vercel; optional locally) ──
# Vercel can't persist the local .data/ files. Create a KV/Redis store in the
# Vercel dashboard (Storage → KV/Upstash) and it injects these automatically.
# When BOTH are unset (local dev), the app falls back to local .data/*.json files.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Native Upstash names also work: UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)

# ── Uploaded documents (REQUIRED on Vercel for the portal docs feature) ──
# Create a Blob store in the Vercel dashboard (Storage → Blob); it injects this.
# Unset locally → uploads go to .data/uploads/.
BLOB_READ_WRITE_TOKEN=

# Number of trusted reverse proxies in front of the app (rate-limit IP accuracy).
# Vercel = 1. Only the right-most hop is trusted; left-most XFF is spoofable.
TRUSTED_PROXY_HOPS=1

# Optional: minimum log level (debug | info | warn | error). Default: info.
LOG_LEVEL=
