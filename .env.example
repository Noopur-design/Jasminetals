# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must NEVER be committed.
# Only NEXT_PUBLIC_* values reach the browser — keep everything else secret.

# ── Firebase web config (PUBLIC — safe to expose in the browser) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Realtime Database URL — REQUIRED (this is the production data store).
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC) ──
# Sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Comma-separated owner-admin emails (full /internal access).
ADMIN_EMAILS=

# Direct admin password (login at /admin without Google). Use a strong value.
ADMIN_PASSWORD=

# ── Firebase Admin service account (REQUIRED on Vercel) ──
# This is the production database AND file store: the Realtime Database holds all
# app data and Firebase Storage holds uploaded client documents. Vercel's
# serverless filesystem is read-only, so the local .data/ store can't persist there.
# Get the key: Firebase Console → Project settings → Service accounts →
# "Generate new private key". Copy client_email and private_key from the JSON.
# IMPORTANT: paste the private key on a single line with literal \n for newlines,
# wrapped in double quotes, e.g.
#   FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# When BOTH are unset (local dev), the app falls back to local .data/*.json files.
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Number of trusted reverse proxies in front of the app (rate-limit IP accuracy).
# Vercel = 1. Only the right-most hop is trusted; left-most XFF is spoofable.
TRUSTED_PROXY_HOPS=1

# Optional: minimum log level (debug | info | warn | error). Default: info.
LOG_LEVEL=
